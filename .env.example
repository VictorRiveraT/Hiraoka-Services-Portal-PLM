# Hiraoka Services - variables de entorno de ejemplo
# Copiar este archivo como .env y reemplazar los valores placeholder por los reales.
# El .env real NO debe subirse al repositorio; compartirlo solo por canal seguro.

# Base de datos PostgreSQL
DB_NAME=hiraoka_services
DB_USER=hiraoka_user
DB_PASSWORD=change_me_use_a_secure_password

# Autenticacion
JWT_SECRET=change_me_minimum_32_characters
JWT_EXPIRATION=30m

# Entorno
NODE_ENV=development

# Puertos internos de servicios
AUTH_SERVICE_PORT=3001
API_GATEWAY_PORT=3000
TICKET_SERVICE_PORT=3002
TALLER_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
LEGACY_SERVICE_PORT=3005

# URLs internas usadas por el api-gateway dentro de Docker Compose
AUTH_SERVICE_URL=http://auth-service:3001
TICKET_SERVICE_URL=http://ticket-service:3002
TALLER_SERVICE_URL=http://taller-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3004
NOTIFICATION_TIMEOUT_MS=3000
LEGACY_SERVICE_URL=http://legacy-service:3005
LEGACY_TIMEOUT_MS=2000
LEGACY_CIRCUIT_BREAKER_FAILURES=3
LEGACY_CIRCUIT_BREAKER_RESET_MS=30000

# Notificaciones por email (SendGrid)
SENDGRID_API_KEY=replace_with_sendgrid_api_key
SENDGRID_FROM_EMAIL=hiraokaservices@gmail.com
PORTAL_URL=http://localhost

# Origenes CORS permitidos, separados por coma. No usar "*".
CORS_ORIGIN=http://localhost,http://localhost:80
